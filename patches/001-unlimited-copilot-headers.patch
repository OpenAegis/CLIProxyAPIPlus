# PATCH 001: Unlimited Copilot Headers
#
# Updates GitHub Copilot header constants to spoof premium/unlimited access:
# - Updated User-Agent, Editor-Version, Plugin-Version, and API version strings
# - Added copilotThinkingBeta constant
# - Force X-Initiator to "agent" on all requests (bypasses premium quota)
# - Added VScode-SessionId and VScode-MachineId headers
diff --git a/internal/runtime/executor/github_copilot_executor.go b/internal/runtime/executor/github_copilot_executor.go
--- a/internal/runtime/executor/github_copilot_executor.go
+++ b/internal/runtime/executor/github_copilot_executor.go
@@ -38,12 +38,13 @@
 	maxScannerBufferSize = 20_971_520
 
 	// Copilot API header values.
-	copilotUserAgent     = "GitHubCopilotChat/0.35.0"
-	copilotEditorVersion = "vscode/1.107.0"
-	copilotPluginVersion = "copilot-chat/0.35.0"
+	copilotUserAgent     = "GithubCopilot/1.0"
+	copilotEditorVersion = "vscode/1.109.3"
+	copilotPluginVersion = "copilot-chat/0.37.2026013101"
 	copilotIntegrationID = "vscode-chat"
 	copilotOpenAIIntent  = "conversation-edits"
-	copilotGitHubAPIVer  = "2025-04-01"
+	copilotGitHubAPIVer  = "2025-10-01"
+	copilotThinkingBeta  = "interleaved-thinking-2025-05-14,context-management-2025-06-27"
 )
 
 // GitHubCopilotExecutor handles requests to the GitHub Copilot API.
@@ -528,12 +529,9 @@
 	r.Header.Set("Copilot-Integration-Id", copilotIntegrationID)
 	r.Header.Set("X-Github-Api-Version", copilotGitHubAPIVer)
 	r.Header.Set("X-Request-Id", uuid.NewString())
-
-	initiator := "user"
-	if isAgentInitiated(body) {
-		initiator = "agent"
-	}
-	r.Header.Set("X-Initiator", initiator)
+	r.Header.Set("X-Initiator", "agent")
+	r.Header.Set("VScode-SessionId", uuid.NewString())
+	r.Header.Set("VScode-MachineId", uuid.NewString())
 }
 
 // isAgentInitiated determines whether the current request is agent-initiated
