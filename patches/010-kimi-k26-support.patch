+	r.Header.Set("User-Agent", "KimiCodeCLI/"+kimiCLIVersion)
 	r.Header.Set("X-Msh-Platform", "kimi_cli")
-	r.Header.Set("X-Msh-Version", "1.10.6")
+	r.Header.Set("X-Msh-Version", kimiCLIVersion)
 	r.Header.Set("X-Msh-Device-Name", getKimiHostname())
 	r.Header.Set("X-Msh-Device-Model", getKimiDeviceModel())
 	r.Header.Set("X-Msh-Device-Id", getKimiDeviceID())
+	r.Header.Set("X-Msh-Os-Version", getKimiOsVersion())
 	if stream {
 		r.Header.Set("Accept", "text/event-stream")
 		return
@@ -513,6 +525,13 @@ func applyKimiHeaders(r *http.Request, token string, stream bool) {
 	r.Header.Set("Accept", "application/json")
 }
 
+// getKimiOsVersion returns an OS version string for the X-Msh-Os-Version
+// header. Mirrors kimi-cli's behaviour of sending a coarse OS identifier so
+// the backend can apply per-platform routing.
+func getKimiOsVersion() string {
+	return fmt.Sprintf("%s %s", runtime.GOOS, runtime.GOARCH)
+}
+
 func resolveKimiDeviceIDFromAuth(auth *cliproxyauth.Auth) string {
 	if auth == nil || auth.Metadata == nil {
 		return ""
@@ -624,10 +643,82 @@ func kimiCreds(a *cliproxyauth.Auth) (token string) {
 	return ""
 }
 
-// stripKimiPrefix removes the "kimi-" prefix from model names for the upstream API.
+// kimiPreservedModels is the set of upstream model IDs that happen to start
+// with the literal prefix "kimi-" but MUST be forwarded to the backend
+// verbatim. In particular "kimi-for-coding" is the on-wire identifier for the
+// K2.6 coding model; stripping the prefix would route the request to a
+// non-existent model and cause the backend to fall back to an older
+// generation.
+var kimiPreservedModels = map[string]struct{}{
+	"kimi-for-coding": {},
+}
+
+// applyKimiPromptCacheKey attaches a deterministic prompt_cache_key to the
+// outgoing request body for the K2.6 coding model. Mirrors kimi-cli behaviour
+// (llm.py: gen_kwargs["prompt_cache_key"] = session_id) so the Kimi backend
+// can reuse its KV cache across turns of the same conversation.
+//
+// Scope: intentionally limited to upstreamModel == "kimi-for-coding" so that
+// behaviour of other Kimi variants (kimi-k2, kimi-k2-thinking, kimi-k2.5, ...)
+// and other providers is completely unchanged.
+//
+// Key derivation: sha256 of (authID || system prompt || first user message).
+// This is stable across turns in a conversation (system + opening user turn
+// rarely change) while still varying per auth account and per conversation,
+// so cache lookups hit but different sessions do not collide. If the body
+// already carries a prompt_cache_key (client-provided), that value wins.
+func applyKimiPromptCacheKey(body []byte, upstreamModel string, auth *cliproxyauth.Auth) []byte {
+	if !strings.EqualFold(strings.TrimSpace(upstreamModel), "kimi-for-coding") {
+		return body
+	}
+	if existing := gjson.GetBytes(body, "prompt_cache_key"); existing.Exists() && strings.TrimSpace(existing.String()) != "" {
+		return body
+	}
+	h := sha256.New()
+	if auth != nil {
+		h.Write([]byte(auth.ID))
+		h.Write([]byte{0})
+	}
+	sys := gjson.GetBytes(body, "system")
+	if sys.Exists() {
+		h.Write([]byte(sys.Raw))
+		h.Write([]byte{0})
+	}
+	msgs := gjson.GetBytes(body, "messages")
+	if msgs.IsArray() {
+		msgs.ForEach(func(_, m gjson.Result) bool {
+			if strings.EqualFold(m.Get("role").String(), "system") {
+				h.Write([]byte(m.Get("content").Raw))
+				h.Write([]byte{0})
+			}
+			return true
+		})
+		msgs.ForEach(func(_, m gjson.Result) bool {
+			if strings.EqualFold(m.Get("role").String(), "user") {
+				h.Write([]byte(m.Get("content").Raw))
+				return false
+			}
+			return true
+		})
+	}
+	key := hex.EncodeToString(h.Sum(nil))[:32]
+	updated, err := sjson.SetBytes(body, "prompt_cache_key", key)
+	if err != nil {
+		return body
+	}
+	return updated
+}
+
+// stripKimiPrefix removes the "kimi-" prefix from model names for the upstream
+// API, except for models explicitly whitelisted in kimiPreservedModels which
+// are sent verbatim.
 func stripKimiPrefix(model string) string {
 	model = strings.TrimSpace(model)
-	if strings.HasPrefix(strings.ToLower(model), "kimi-") {
+	lower := strings.ToLower(model)
+	if _, preserved := kimiPreservedModels[lower]; preserved {
+		return model
+	}
+	if strings.HasPrefix(lower, "kimi-") {
 		return model[5:]
 	}
 	return model
diff --git a/internal/thinking/provider/kimi/apply.go b/internal/thinking/provider/kimi/apply.go
index ff47c46d..97cec304 100644
--- a/internal/thinking/provider/kimi/apply.go
+++ b/internal/thinking/provider/kimi/apply.go
@@ -131,6 +131,11 @@ func applyCompatibleKimi(body []byte, config thinking.ThinkingConfig) ([]byte, e
 }
 
 func applyReasoningEffort(body []byte, effort string) ([]byte, error) {
+	// Mirror the upstream Kimi Code CLI (kosong SDK) which sends BOTH
+	// reasoning_effort and thinking.type="enabled" simultaneously when
+	// thinking is active. Sending only reasoning_effort causes some model
+	// generations (notably K2.6 / kimi-for-coding) to run with thinking
+	// silently disabled.
 	result, errDeleteThinking := sjson.DeleteBytes(body, "thinking")
 	if errDeleteThinking != nil {
 		return body, fmt.Errorf("kimi thinking: failed to clear thinking object: %w", errDeleteThinking)
@@ -139,6 +144,10 @@ func applyReasoningEffort(body []byte, effort string) ([]byte, error) {
 	if errSetEffort != nil {
 		return body, fmt.Errorf("kimi thinking: failed to set reasoning_effort: %w", errSetEffort)
 	}
+	result, errSetType := sjson.SetBytes(result, "thinking.type", "enabled")
+	if errSetType != nil {
+		return body, fmt.Errorf("kimi thinking: failed to set thinking.type: %w", errSetType)
+	}
 	return result, nil
 }
 
