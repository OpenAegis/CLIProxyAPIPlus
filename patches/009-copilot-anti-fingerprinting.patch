+func copilotHeaderFingerprint(apiToken string) (userAgent, editorVersion, pluginVersion, sessionID, machineID string) {
+	userAgent = copilotUserAgent
+	editorVersion = copilotEditorVersion
+	pluginVersion = copilotPluginVersion
+	if strings.TrimSpace(apiToken) == "" {
+		return userAgent, editorVersion, pluginVersion, uuid.NewString(), uuid.NewString()
+	}
+	userAgent = copilotUserAgents[copilotPickIndex(apiToken, "ua", len(copilotUserAgents))]
+	editorVersion = copilotEditorVersions[copilotPickIndex(apiToken, "editor", len(copilotEditorVersions))]
+	pluginVersion = copilotPluginVersions[copilotPickIndex(apiToken, "plugin", len(copilotPluginVersions))]
+	return userAgent, editorVersion, pluginVersion, copilotSessionID(apiToken), copilotMachineID(apiToken)
+}
