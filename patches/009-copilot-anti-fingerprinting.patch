+func copilotConversationHasPreviousResponseID(body []byte) bool {
+	if len(body) == 0 {
+		return false
+	}
+	return strings.TrimSpace(gjson.GetBytes(body, "previous_response_id").String()) != ""
+}
+
+func isCopilotWarmConversationRootRole(role string) bool {
+	switch strings.TrimSpace(role) {
+	case "user", "system", "developer":
+		return true
+	default:
+		return false
+	}
+}
+
+func copilotWarmConversationRootKey(apiToken string, body []byte) string {
+	if len(body) == 0 {
+		return ""
+	}
+
+	var root strings.Builder
+	appendRootPart := func(label string, part gjson.Result) {
+		if !part.Exists() {
+			return
+		}
+		root.WriteString(label)
+		root.WriteByte(':')
+		root.WriteString(part.Raw)
+		root.WriteByte('\n')
+	}
+
+	if instructions := gjson.GetBytes(body, "instructions"); instructions.Exists() {
+		appendRootPart("instructions", instructions)
+	}
+	if system := gjson.GetBytes(body, "system"); system.Exists() {
+		appendRootPart("system", system)
+	}
+	if messages := gjson.GetBytes(body, "messages"); messages.Exists() && messages.IsArray() {
+		for _, msg := range messages.Array() {
+			role := msg.Get("role").String()
+			if role == "" {
+				continue
+			}
+			if !isCopilotWarmConversationRootRole(role) {
+				break
+			}
+			appendRootPart("message", msg)
+		}
+	}
+	if root.Len() == 0 {
+		if input := gjson.GetBytes(body, "input"); input.Exists() {
+			if input.IsArray() {
+				for _, item := range input.Array() {
+					itemType := item.Get("type").String()
+					role := item.Get("role").String()
+					if itemType == "" && role != "" {
+						itemType = "message"
+					}
+					if itemType != "message" || !isCopilotWarmConversationRootRole(role) {
+						break
+					}
+					appendRootPart("input", item)
+				}
+			} else if input.Type == gjson.String {
+				appendRootPart("input", input)
+			}
+		}
+	}
+	if root.Len() == 0 {
+		return ""
+	}
+
+	sum := sha256.Sum256([]byte(apiToken + "\n" + root.String()))
+	return "copilot-conversation:" + hex.EncodeToString(sum[:])
+}
+
+func copilotWarmConversationSessionKey(apiToken, sessionID string) string {
+	sessionID = strings.TrimSpace(sessionID)
+	if sessionID == "" {
+		return ""
+	}
+	sum := sha256.Sum256([]byte(apiToken + "\n" + sessionID))
+	return "copilot-session:" + hex.EncodeToString(sum[:])
+}
+
+func copilotExecutionSessionID(ctx context.Context, opts cliproxyexecutor.Options) string {
+	if sessionID := metaStringValue(opts.Metadata, cliproxyexecutor.ExecutionSessionMetadataKey); sessionID != "" {
+		return sessionID
+	}
+	if opts.Headers != nil {
+		if sessionID := strings.TrimSpace(opts.Headers.Get(copilotWarmConversationSessionHeader)); sessionID != "" {
+			return sessionID
+		}
+	}
+	if ctx == nil {
+		return ""
+	}
+	ginCtx, ok := ctx.Value("gin").(*gin.Context)
+	if !ok || ginCtx == nil {
+		return ""
+	}
+	return strings.TrimSpace(ginCtx.GetHeader(copilotWarmConversationSessionHeader))
+}
+
+func copilotWarmConversationKeys(ctx context.Context, opts cliproxyexecutor.Options, apiToken string, body []byte) []string {
+	keys := make([]string, 0, 2)
+	seen := make(map[string]struct{}, 2)
+	addKey := func(key string) {
+		if key == "" {
+			return
+		}
+		if _, ok := seen[key]; ok {
+			return
+		}
+		seen[key] = struct{}{}
+		keys = append(keys, key)
+	}
+
+	addKey(copilotWarmConversationRootKey(apiToken, body))
+	addKey(copilotWarmConversationSessionKey(apiToken, copilotExecutionSessionID(ctx, opts)))
+	return keys
+}
+
+func (e *GitHubCopilotExecutor) clearCopilotWarmConversationReservation(ctx context.Context, opts cliproxyexecutor.Options, apiToken string, body []byte) {
+	keys := copilotWarmConversationKeys(ctx, opts, apiToken, body)
+	if len(keys) == 0 {
+		return
+	}
+
+	now := time.Now()
+	e.warmMu.Lock()
+	for key, expiresAt := range e.warmingConversations {
+		if !expiresAt.After(now) {
+			delete(e.warmingConversations, key)
+		}
+	}
+	for _, key := range keys {
+		delete(e.warmingConversations, key)
+	}
+	e.warmMu.Unlock()
+}
+
+func (e *GitHubCopilotExecutor) markCopilotWarmConversation(ctx context.Context, opts cliproxyexecutor.Options, apiToken string, body []byte) {
+	keys := copilotWarmConversationKeys(ctx, opts, apiToken, body)
+	if len(keys) == 0 {
+		return
+	}
+
+	e.ensureCopilotWarmConversationCleanup()
+
+	now := time.Now()
+	newExpiry := now.Add(copilotWarmConversationTTL)
+	refreshThreshold := now.Add(copilotWarmConversationTTL / 2)
+	var snapshot map[string]time.Time
+
+	e.warmMu.Lock()
+	if e.warmConversations == nil {
+		e.warmConversations = make(map[string]time.Time)
+	}
+	if e.warmingConversations == nil {
+		e.warmingConversations = make(map[string]time.Time)
+	}
+	refreshNeeded := false
+	for _, key := range keys {
+		delete(e.warmingConversations, key)
+		if expiresAt, ok := e.warmConversations[key]; !ok || !expiresAt.After(refreshThreshold) {
+			refreshNeeded = true
+		}
+	}
+	if refreshNeeded {
+		for _, key := range keys {
+			e.warmConversations[key] = newExpiry
+		}
+		snapshot = e.snapshotCopilotWarmConversationsLocked(now)
+	}
+	e.warmMu.Unlock()
+
+	if refreshNeeded {
+		e.persistCopilotWarmConversations(snapshot)
+	}
+}
+
+func (e *GitHubCopilotExecutor) shouldUseCopilotAgentInitiator(ctx context.Context, opts cliproxyexecutor.Options, apiToken, requestID string, body []byte) bool {
+	if len(body) == 0 {
+		return true
+	}
+	if isAgentInitiated(body) || copilotConversationHasPreviousResponseID(body) {
+		return true
+	}
+
+	keys := copilotWarmConversationKeys(ctx, opts, apiToken, body)
+	if len(keys) == 0 {
+		return false
+	}
+	sessionKey := copilotWarmConversationSessionKey(apiToken, copilotExecutionSessionID(ctx, opts))
+	if sessionKey != "" && e.isCopilotWarmConversation(sessionKey) {
+		return true
+	}
+	for _, key := range keys {
+		if key == sessionKey {
+			continue
+		}
+		if e.isCopilotWarmConversation(key) {
+			return !copilotShouldUseWarmConversationRealInitiator(apiToken, requestID)
+		}
+	}
+	if e.reserveCopilotWarmConversation(keys) {
+		return false
+	}
+	return true
+}
