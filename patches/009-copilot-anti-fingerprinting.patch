+func copilotTokenHash(apiToken string) [32]byte {
+	return sha256.Sum256([]byte(apiToken))
+}
+
+func copilotMachineID(apiToken string) string {
+	hash := copilotTokenHash(apiToken)
+	return hex.EncodeToString(hash[:])
+}
+
+func copilotSessionID(apiToken string) string {
+	bucket := time.Now().Unix() / int64(copilotSessionRotation.Seconds())
+	hash := sha256.Sum256([]byte(fmt.Sprintf("%s:%d", apiToken, bucket)))
+	hexStr := hex.EncodeToString(hash[:16])
+	return fmt.Sprintf("%s-%s-%s-%s-%s", hexStr[0:8], hexStr[8:12], hexStr[12:16], hexStr[16:20], hexStr[20:32])
+}
+
+func copilotPickIndex(apiToken, salt string, poolSize int) int {
+	hash := sha256.Sum256([]byte(apiToken + ":" + salt))
+	return int(binary.BigEndian.Uint16(hash[:2]) % uint16(poolSize))
+}
+
+func copilotHashUnitInterval(apiToken, requestID, salt string) float64 {
+	hash := sha256.Sum256([]byte(apiToken + ":" + requestID + ":" + salt))
+	value := binary.BigEndian.Uint64(hash[:8])
+	return float64(value>>11) / (1 << 53)
+}
+
+func copilotShouldUseWarmConversationRealInitiator(apiToken, requestID string) bool {
+	return copilotHashUnitInterval(apiToken, requestID, "warm-real-initiator") < copilotWarmConversationRealRatio
+}
