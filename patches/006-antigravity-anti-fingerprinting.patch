+func compareVersions(a, b string) int {
+	partsA := strings.SplitN(strings.TrimSpace(a), ".", 3)
+	partsB := strings.SplitN(strings.TrimSpace(b), ".", 3)
+	for i := 0; i < 3; i++ {
+		var na, nb int
+		if i < len(partsA) {
+			na, _ = strconv.Atoi(partsA[i])
+		}
+		if i < len(partsB) {
+			nb, _ = strconv.Atoi(partsB[i])
+		}
+		switch {
+		case na < nb:
+			return -1
+		case na > nb:
+			return 1
+		}
+	}
+	return 0
+}
