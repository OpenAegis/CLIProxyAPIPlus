+func copilotWarmConversationSessionKey(apiToken string, sessionID string) string {
+	sessionID = strings.TrimSpace(sessionID)
+	if sessionID == "" {
+		return ""
+	}
+
+	sum := sha256.Sum256([]byte(apiToken + "\n" + sessionID))
+	return "copilot-session:" + hex.EncodeToString(sum[:])
+}
+
+func copilotExecutionSessionID(ctx context.Context, opts cliproxyexecutor.Options) string {
+	if sessionID := metaStringValue(opts.Metadata, cliproxyexecutor.ExecutionSessionMetadataKey); sessionID != "" {
+		return sessionID
+	}
+	if opts.Headers != nil {
+		if sessionID := strings.TrimSpace(opts.Headers.Get(copilotWarmConversationSessionHeader)); sessionID != "" {
+			return sessionID
+		}
+	}
+	if ctx == nil {
+		return ""
+	}
+	ginCtx, ok := ctx.Value("gin").(*gin.Context)
+	if !ok || ginCtx == nil {
+		return ""
+	}
+	return strings.TrimSpace(ginCtx.GetHeader(copilotWarmConversationSessionHeader))
+}
+
+func copilotWarmConversationKeys(ctx context.Context, opts cliproxyexecutor.Options, apiToken string, body []byte) []string {
+	keys := make([]string, 0, 2)
+	seen := make(map[string]struct{}, 2)
+	addKey := func(key string) {
+		if key == "" {
+			return
+		}
+		if _, ok := seen[key]; ok {
+			return
+		}
+		seen[key] = struct{}{}
+		keys = append(keys, key)
+	}
+
+	addKey(copilotWarmConversationRootKey(apiToken, body))
+	addKey(copilotWarmConversationSessionKey(apiToken, copilotExecutionSessionID(ctx, opts)))
+	return keys
+}
