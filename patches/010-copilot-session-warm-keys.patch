+	e2 := NewGitHubCopilotExecutor(cfg)
+	req, _ := http.NewRequest(http.MethodPost, "https://example.com", nil)
+	req.Header.Set("X-Request-Id", findCopilotWarmConversationRequestID(t, false))
+	e2.applyHeaders(req, "token", sdktranslator.FormatOpenAI, compactedBody, nil, opts)
+	if got := req.Header.Get("X-Initiator"); got != "agent" {
+		t.Fatalf("X-Initiator = %q, want agent for compacted turn restored via session affinity key", got)
+	}
+}
