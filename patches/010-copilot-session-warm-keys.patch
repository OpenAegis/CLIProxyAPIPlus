+func TestApplyHeaders_XInitiator_WarmConversationSessionMetadataSurvivesCompaction(t *testing.T) {
+	t.Parallel()
+	e := &GitHubCopilotExecutor{warmConversations: make(map[string]time.Time)}
+	opts := cliproxyexecutor.Options{
+		Metadata: map[string]any{
+			cliproxyexecutor.ExecutionSessionMetadataKey: "session-123",
+		},
+	}
+	rootBody := []byte(`{"messages":[{"role":"user","content":"help me debug this proxy"}]}`)
+	compactedBody := []byte(`{"messages":[{"role":"user","content":"What did we do so far?"}]}`)
+	e.markCopilotWarmConversation(nil, opts, "token", rootBody)
+
+	req, _ := http.NewRequest(http.MethodPost, "https://example.com", nil)
+	req.Header.Set("X-Request-Id", findCopilotWarmConversationRequestID(t, false))
+	e.applyHeaders(req, "token", sdktranslator.FormatOpenAI, compactedBody, nil, opts)
+	if got := req.Header.Get("X-Initiator"); got != "agent" {
+		t.Fatalf("X-Initiator = %q, want agent for compacted turn in warmed execution session", got)
+	}
+}
